{
  "name": "hono-api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "keywords": [],
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "serve": "bun src/server.ts",
    "build": "bun build ./src/server.ts --outdir ./dist --target=bun --external sharp",
    "start": "bun ./dist/server.js",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "auth:generate": "bunx @better-auth/cli generate --config src/auth.ts --output src/db/schema/auth.ts -y",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bun scripts/migrate.ts",
    "db:push": "bunx drizzle-kit push",
    "db:studio": "bunx drizzle-kit studio"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@better-auth/expo": "^1.6.20",
    "@scalar/hono-api-reference": "^0.10.12",
    "better-auth": "^1.6.20",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.16",
    "hono-openapi": "^1.3.0",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3"
  }
}
